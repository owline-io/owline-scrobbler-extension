{
  "manifest_version": 3,
  "name": "Owline Scrobbler",
  "version": "1.0.0",
  "description": "Scrobble what you listen to on Spotify, YouTube, SoundCloud and Deezer to Owline.",
  "minimum_chrome_version": "92",
  "permissions": ["storage", "alarms", "identity"],
  "host_permissions": [
    "https://api.owline.io/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icon-48.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://open.spotify.com/*"],
      "js": ["shared/config.js", "shared/storage-keys.js", "content/base.js", "content/providers/spotify.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.youtube.com/*"],
      "exclude_matches": ["https://music.youtube.com/*"],
      "js": ["shared/config.js", "shared/storage-keys.js", "content/base.js", "content/providers/youtube.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["shared/config.js", "shared/storage-keys.js", "content/base.js", "content/providers/youtube-music.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://soundcloud.com/*"],
      "js": ["shared/config.js", "shared/storage-keys.js", "content/base.js", "content/providers/soundcloud.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.deezer.com/*"],
      "js": ["shared/config.js", "shared/storage-keys.js", "content/base.js", "content/providers/deezer.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://listen.tidal.com/*"],
      "js": ["shared/config.js", "shared/storage-keys.js", "content/base.js", "content/providers/tidal.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://music.amazon.com/*",
        "https://music.amazon.com.br/*",
        "https://music.amazon.co.uk/*",
        "https://music.amazon.de/*",
        "https://music.amazon.fr/*",
        "https://music.amazon.es/*",
        "https://music.amazon.it/*",
        "https://music.amazon.com.mx/*",
        "https://music.amazon.ca/*",
        "https://music.amazon.co.jp/*",
        "https://music.amazon.in/*",
        "https://music.amazon.com.au/*"
      ],
      "js": ["shared/config.js", "shared/storage-keys.js", "content/base.js", "content/providers/amazon-music.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://music.apple.com/*"],
      "js": ["shared/config.js", "shared/storage-keys.js", "content/base.js", "content/providers/apple-music.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.bandcamp.com/*",
        "https://bandcamp.com/*"
      ],
      "js": ["shared/config.js", "shared/storage-keys.js", "content/base.js", "content/providers/bandcamp.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://app.plex.tv/*"],
      "js": ["shared/config.js", "shared/storage-keys.js", "content/base.js", "content/providers/plex.js"],
      "run_at": "document_idle"
    }
  ]
}
