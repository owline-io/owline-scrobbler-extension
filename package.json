{
  "name": "owline-scrobbler-extension",
  "version": "1.1.0",
  "private": true,
  "description": "Owline Scrobbler Chrome extension",
  "scripts": {
    "test": "node --test tests/*.test.js tests/providers/*.test.js",
    "lint": "eslint . --max-warnings 0",
    "bump": "node scripts/bump.js",
    "build": "rm -f build/owline-scrobbler.zip && zip -r build/owline-scrobbler.zip manifest.json background.js popup content shared icons -x '*.DS_Store'"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "globals": "^15.0.0"
  }
}
